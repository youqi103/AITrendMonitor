datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model MonitorTerm {
  id        String   @id @default(cuid())
  word      String
  scope     String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  alerts    Alert[]

  @@index([status])
}

model NewsItem {
  id          String     @id @default(cuid())
  title       String
  content     String
  source      String
  url         String
  urlHash     String     @unique
  publishedAt DateTime
  crawledAt   DateTime   @default(now())
  aiSummary   String?
  isVerified  Boolean    @default(false)
  sentiment   String?
  alerts      Alert[]
  trends      TrendItem[]
}

model Alert {
  id           String      @id @default(cuid())
  monitorTermId String
  monitorTerm  MonitorTerm @relation(fields: [monitorTermId], references: [id], onDelete: Cascade)
  newsId       String
  news         NewsItem    @relation(fields: [newsId], references: [id], onDelete: Cascade)
  type         String
  message      String
  isRead       Boolean     @default(false)
  createdAt    DateTime    @default(now())
}

model TrendItem {
  id        String    @id @default(cuid())
  title     String
  summary   String
  heatScore Int       @default(0)
  category  String?
  newsId    String?
  news      NewsItem? @relation(fields: [newsId], references: [id], onDelete: SetNull)
  createdAt DateTime  @default(now())
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model SearchHistory {
  id         String   @id @default(cuid())
  query      String
  source     String
  results    Int      @default(0)
  createdAt  DateTime @default(now())
}

model NotificationSetting {
  id         String   @id @default(cuid())
  email      String?
  emailEnabled Boolean @default(false)
  websocketEnabled Boolean @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
